# VideoCall Server Environment Variables
# Copy to .env and fill in values

# Server
NODE_ENV=development
PORT=3000

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# JWT
JWT_SECRET=change-this-to-a-strong-64-char-secret
JWT_REFRESH_SECRET=change-this-to-another-strong-64-char-secret

# Redis (leave empty for in-memory fallback in dev)
REDIS_URL=

# TURN Server
TURN_URL=turn:your-turn-server:3478
TURN_SECRET=change-this-turn-secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=VideoCall <noreply@videocall.app>

# Grafana
GRAFANA_PASSWORD=admin

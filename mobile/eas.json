{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_NO_HERMES_X86": "1"
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "image": "latest",
        "credentialsSource": "local"
      },
      "env": {
        "EX_DEV_CLIENT_NETWORK_INSPECTOR": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}

{
  "expo": {
    "name": "Aux",
    "slug": "videocall",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0a0a1a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aux.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Aux needs camera access for video calls",
        "NSMicrophoneUsageDescription": "Aux needs microphone access for audio calls",
        "UIBackgroundModes": ["voip", "audio"]
      },
      "bitcode": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.aux.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Aux needs camera access for video calls",
          "microphonePermission": "Aux needs microphone access for audio calls",
          "androidAbiFilters": ["arm64-v8a"]
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],
    "extra": {
      "eas": {
        "projectId": "ba785776-f564-4591-b50f-fd325cc41e26"
      }
    }
  }
}
